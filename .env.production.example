# Copy to .env on the production host:  cp .env.production.example .env
# Then fill in real values. Never commit the populated file.

# ── PostgreSQL ────────────────────────────────────────────────
# Use STRONG, randomly generated values in prod:
#   openssl rand -hex 24
POSTGRES_USER=mcees
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=mcees_db

# These two are derived from the above; keep them in sync.
POSTGRES_URL=postgresql://mcees:CHANGE_ME_strong_random_password@postgres:5432/mcees_db
DATABASE_URL=postgresql://mcees:CHANGE_ME_strong_random_password@postgres:5432/mcees_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Odoo ERP ──────────────────────────────────────────────────
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database
ODOO_USER=admin@example.com
ODOO_PASSWORD=CHANGE_ME

# ── Webhook signing secrets ──────────────────────────────────
# Get these from each platform's webhook configuration UI.
# Generate fresh secrets there with: openssl rand -hex 32
SHOPIFY_WEBHOOK_SECRET=CHANGE_ME_from_shopify_admin
WOOCOMMERCE_WEBHOOK_SECRET=CHANGE_ME_from_woocommerce_admin

# ── Dashboard auth ───────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
# Rotating this invalidates all active sessions.
AUTH_SECRET=CHANGE_ME_64_hex_chars

# ── Caddy / TLS ──────────────────────────────────────────────
# Your DNS A-record points this domain at the VM's public IP.
PUBLIC_DOMAIN=mcees.example.com
# Used by Let's Encrypt for cert-expiry notifications.
ACME_EMAIL=you@example.com
