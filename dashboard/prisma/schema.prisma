generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WebhookSource {
  SHOPIFY
  WOOCOMMERCE
}

enum WebhookStatus {
  RECEIVED
  PROCESSING
  SYNCED
  FAILED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  name          String
  role          UserRole @default(VIEWER)
  is_active     Boolean  @default(true)
  last_login_at DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([email])
}

model WebhookEvent {
  id          String        @id @default(uuid())
  source      WebhookSource
  event_type  String
  external_id String
  raw_payload Json
  status      WebhookStatus @default(RECEIVED)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  logs SyncLog[]

  @@unique([source, external_id])
  @@index([status])
  @@index([created_at])
}

model SyncLog {
  id               String       @id @default(uuid())
  webhook_event_id String
  message          String
  level            LogLevel     @default(INFO)
  created_at       DateTime     @default(now())

  event WebhookEvent @relation(fields: [webhook_event_id], references: [id], onDelete: Cascade)

  @@index([webhook_event_id])
}

// Editable connector / sync-rule configuration stored in the database.
// Secrets (webhook signing keys, Odoo password) are never stored here —
// they are read-only from the backend environment via the /api/config/reveal route.
model AppConfig {
  key        String   @id
  value      String
  updated_at DateTime @updatedAt
}
